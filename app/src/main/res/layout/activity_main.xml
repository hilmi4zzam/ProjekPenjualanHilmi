<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <ImageView
        android:layout_width="65dp"
        android:layout_height="40dp"
        android:background="@drawable/logohlmz"
        android:layout_marginTop="50dp"
        android:layout_marginLeft="30dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"/>

    <ImageView
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@drawable/img"
        android:layout_marginTop="50dp"
        android:layout_marginRight="30dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintRight_toRightOf="parent"/>

    <TextView
        android:id="@+id/haihilmi"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/alata"
        android:text="Hai Hilmi Besar"
        android:textAppearance="@style/TextAppearance.AppCompat.Body1"
        android:textSize="42dp"
        android:textStyle="bold"
        tools:layout_editor_absoluteX="30dp"
        tools:layout_editor_absoluteY="137dp"
        tools:ignore="MissingConstraints" />

    <TextView
        android:id="@+id/selamatdatang"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="57dp"
        android:fontFamily="@font/alata"
        tools:ignore="MissingConstraints"
        android:text="Selamat datang!"
        android:textAppearance="@style/TextAppearance.AppCompat.Body1"
        android:textSize="15sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="@+id/haihilmi"
        tools:layout_editor_absoluteX="30dp" />

    <ImageView
        android:layout_width="600dp"
        android:layout_height="260dp"
        android:background="@drawable/oval"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/kolomSaldo"
        android:layout_marginTop="30dp"/>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:layout_marginTop="25dp"
        android:id="@+id/kolomSaldo"
        app:cardCornerRadius="25dp"
        android:background="@drawable/backgroundkotaksaldo"
        android:layout_marginStart="30dp"
        android:layout_marginEnd="30dp"
        app:layout_constraintTop_toBottomOf="@id/selamatdatang">

        <TextView
            android:layout_width=""
            android:layout_height=""/>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="0dp"
        android:layout_height="95dp"
        android:id="@+id/menu1"
        android:layout_marginTop="20dp"
        android:layout_marginEnd="7dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/menu2"
        app:layout_constraintTop_toBottomOf="@id/kolomSaldo"
        android:background="@drawable/backgroundkotakmenu"
        android:layout_marginStart="30dp">



    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="0dp"
        android:layout_height="95dp"
        android:id="@+id/menu2"
        android:layout_marginEnd="7dp"
        android:layout_marginTop="20dp"
        android:layout_marginStart="7dp"
        app:layout_constraintStart_toEndOf="@id/menu1"
        app:layout_constraintEnd_toStartOf="@id/menu3"
        app:layout_constraintTop_toBottomOf="@id/kolomSaldo"
        android:background="@drawable/backgroundkotakmenu"
        >



    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="0dp"
        android:layout_height="95dp"
        android:id="@+id/menu3"
        android:layout_marginStart="7dp"
        android:layout_marginTop="20dp"
        app:layout_constraintStart_toEndOf="@id/menu2"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/kolomSaldo"
        android:background="@drawable/backgroundkotakmenu"
        android:layout_marginEnd="30dp">



    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="0dp"
        android:layout_height="95dp"
        android:id="@+id/menu4"
        android:layout_marginTop="20dp"
        android:layout_marginEnd="7dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/menu5"
        app:layout_constraintTop_toBottomOf="@id/menu1"
        android:background="@drawable/backgroundkotakmenu"
        android:layout_marginStart="30dp">



    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="0dp"
        android:layout_height="95dp"
        android:id="@+id/menu5"
        android:layout_marginEnd="7dp"
        android:layout_marginTop="20dp"
        android:layout_marginStart="7dp"
        app:layout_constraintStart_toEndOf="@id/menu4"
        app:layout_constraintEnd_toStartOf="@id/menu6"
        app:layout_constraintTop_toBottomOf="@id/menu2"
        android:background="@drawable/backgroundkotakmenu"
        >



    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="0dp"
        android:layout_height="95dp"
        android:id="@+id/menu6"
        android:layout_marginStart="7dp"
        android:layout_marginTop="20dp"
        app:layout_constraintStart_toEndOf="@id/menu5"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/menu3"
        android:background="@drawable/backgroundkotakmenu"
        android:layout_marginEnd="30dp">



    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>