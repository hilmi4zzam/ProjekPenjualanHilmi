<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <ImageView
        android:layout_width="85dp"
        android:layout_height="30dp"
        android:layout_marginTop="50dp"
        android:layout_marginLeft="30dp"
        android:background="@drawable/logohlmz"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"/>

    <ImageView
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:background="@drawable/img"
        android:layout_marginTop="50dp"
        android:layout_marginRight="30dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintRight_toRightOf="parent"/>

    <TextView
        android:id="@+id/haihilmi"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/alata"
        android:text="Halo Hilmi!"
        android:textColor="@color/black"
        android:textSize="42dp"
        android:textStyle="bold"
        android:layout_marginTop="137dp"
        android:layout_marginLeft="30dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"/>

    <TextView
        android:id="@+id/selamatdatang"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="57dp"
        android:fontFamily="@font/alata"
        android:text="Selamat datang!"
        android:textColor="@color/black"
        android:textSize="15sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="@+id/haihilmi"
        app:layout_constraintLeft_toLeftOf="parent"
        android:layout_marginLeft="30dp"/>

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="400dp"
        android:background="@drawable/kotak"
        app:layout_constraintBottom_toBottomOf="parent"/>

    <ImageView
        android:layout_width="600dp"
        android:layout_height="260dp"
        android:background="@drawable/oval"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/kolomSaldo"
        android:layout_marginTop="30dp"/>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:layout_marginTop="25dp"
        android:id="@+id/kolomSaldo"
        app:cardCornerRadius="25dp"
        android:background="@drawable/backgroundkotaksaldo"
        android:layout_marginStart="30dp"
        android:layout_marginEnd="30dp"
        app:layout_constraintTop_toBottomOf="@id/selamatdatang">

            <TextView
                android:id="@+id/tvSaldoAnda"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/black"
                android:text="Saldo Anda :"
                android:fontFamily="@font/alata"
                android:textSize="15sp"
                android:textStyle="bold"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                android:layout_marginLeft="25dp"
                android:layout_marginTop="27dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/black"
            android:text="1.000.000"
            android:fontFamily="@font/alata"
            android:textStyle="bold"
            android:textSize="34dp"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintTop_toTopOf="@id/tvSaldoAnda"
            android:layout_marginLeft="25dp"
            android:layout_marginTop="12dp"/>

        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/logotransaksi"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:background="@drawable/img_1"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:layout_marginRight="18dp"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_marginTop="6dp"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="0dp"
        android:layout_height="95dp"
        android:id="@+id/menu1"
        android:layout_marginTop="20dp"
        android:layout_marginEnd="7dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/menu2"
        app:layout_constraintTop_toBottomOf="@id/kolomSaldo"
        android:background="@drawable/backgroundkotakmenu"
        android:layout_marginStart="30dp">

        <de.hdodenhof.circleimageview.CircleImageView
            android:layout_width="50dp"
            android:id="@+id/logoproduk"
            android:layout_height="50dp"
            android:background="@drawable/img_4"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="13dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@id/tvproduk"/>

        <TextView
            android:layout_width="wrap_content"
            android:id="@+id/tvproduk"
            android:layout_height="wrap_content"
            android:text="Produk"
            android:layout_marginBottom="10dp"
            android:fontFamily="@font/alata"
            android:textSize="15sp"
            android:textColor="@color/black"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toBottomOf="@id/logoproduk"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="0dp"
        android:layout_height="95dp"
        android:id="@+id/menu2"
        android:layout_marginEnd="7dp"
        android:layout_marginTop="20dp"
        android:layout_marginStart="7dp"
        app:layout_constraintStart_toEndOf="@id/menu1"
        app:layout_constraintEnd_toStartOf="@id/menu3"
        app:layout_constraintTop_toBottomOf="@id/kolomSaldo"
        android:background="@drawable/backgroundkotakmenu">

        <de.hdodenhof.circleimageview.CircleImageView
            android:layout_width="50dp"
            android:id="@+id/logokategori"
            android:layout_height="50dp"
            android:background="@drawable/img_2"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="13dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@id/tvkategori"/>

        <TextView
            android:layout_width="wrap_content"
            android:id="@+id/tvkategori"
            android:layout_height="wrap_content"
            android:text="Kategori"
            android:layout_marginBottom="10dp"
            android:fontFamily="@font/alata"
            android:textSize="15sp"
            android:textColor="@color/black"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toBottomOf="@id/logokategori"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="0dp"
        android:layout_height="95dp"
        android:id="@+id/menu3"
        android:layout_marginStart="7dp"
        android:layout_marginTop="20dp"
        app:layout_constraintStart_toEndOf="@id/menu2"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/kolomSaldo"
        android:background="@drawable/backgroundkotakmenu"
        android:layout_marginEnd="30dp">

        <de.hdodenhof.circleimageview.CircleImageView
            android:layout_width="50dp"
            android:id="@+id/logocabang"
            android:layout_height="50dp"
            android:background="@drawable/img_5"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="13dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@id/tvcabang"/>

        <TextView
            android:layout_width="wrap_content"
            android:id="@+id/tvcabang"
            android:layout_height="wrap_content"
            android:text="Cabang"
            android:layout_marginBottom="10dp"
            android:fontFamily="@font/alata"
            android:textSize="15sp"
            android:textColor="@color/black"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toBottomOf="@id/logocabang"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="0dp"
        android:layout_height="95dp"
        android:id="@+id/menu4"
        android:layout_marginTop="20dp"
        android:layout_marginEnd="7dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/menu5"
        app:layout_constraintTop_toBottomOf="@id/menu1"
        android:background="@drawable/backgroundkotakmenu"
        android:layout_marginStart="30dp">

        <de.hdodenhof.circleimageview.CircleImageView
            android:layout_width="50dp"
            android:id="@+id/logopegawai"
            android:layout_height="50dp"
            android:background="@drawable/img_6"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="13dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@id/tvpegawai"/>

        <TextView
            android:layout_width="wrap_content"
            android:id="@+id/tvpegawai"
            android:layout_height="wrap_content"
            android:text="Pegawai"
            android:layout_marginBottom="10dp"
            android:fontFamily="@font/alata"
            android:textSize="15sp"
            android:textColor="@color/black"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toBottomOf="@id/logopegawai"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="0dp"
        android:layout_height="95dp"
        android:id="@+id/menu5"
        android:layout_marginEnd="7dp"
        android:layout_marginTop="20dp"
        android:layout_marginStart="7dp"
        app:layout_constraintStart_toEndOf="@id/menu4"
        app:layout_constraintEnd_toStartOf="@id/menu6"
        app:layout_constraintTop_toBottomOf="@id/menu2"
        android:background="@drawable/backgroundkotakmenu">

        <de.hdodenhof.circleimageview.CircleImageView
            android:layout_width="50dp"
            android:id="@+id/logoprinter"
            android:layout_height="50dp"
            android:background="@drawable/img_7"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="13dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@id/tvprinter"/>

        <TextView
            android:layout_width="wrap_content"
            android:id="@+id/tvprinter"
            android:layout_height="wrap_content"
            android:text="Printer"
            android:layout_marginBottom="10dp"
            android:fontFamily="@font/alata"
            android:textSize="15sp"
            android:textColor="@color/black"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toBottomOf="@id/logoprinter"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="0dp"
        android:layout_height="95dp"
        android:id="@+id/menu6"
        android:layout_marginStart="7dp"
        android:layout_marginTop="20dp"
        app:layout_constraintStart_toEndOf="@id/menu5"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/menu3"
        android:background="@drawable/backgroundkotakmenu"
        android:layout_marginEnd="30dp">

        <de.hdodenhof.circleimageview.CircleImageView
            android:layout_width="50dp"
            android:id="@+id/logolaporan"
            android:layout_height="50dp"
            android:background="@drawable/img_3"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="13dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@id/tvlaporan"/>

        <TextView
            android:layout_width="wrap_content"
            android:id="@+id/tvlaporan"
            android:layout_height="wrap_content"
            android:text="Laporan"
            android:layout_marginBottom="10dp"
            android:fontFamily="@font/alata"
            android:textSize="15sp"
            android:textColor="@color/black"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toBottomOf="@id/logolaporan"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>