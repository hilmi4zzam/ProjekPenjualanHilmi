<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".kategori.dataKategoriActivity">

    <com.google.android.material.card.MaterialCardView
        android:layout_marginStart="15dp"
        android:layout_marginEnd="15dp"
        android:layout_marginHorizontal="8dp"
        android:layout_marginTop="30dp"
        app:cardCornerRadius="23dp"
        app:layout_constraintTop_toTopOf="parent"
        android:id="@+id/searchDataKategori"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <androidx.appcompat.widget.SearchView
            android:layout_width="match_parent"
            android:layout_height="60dp"
            app:iconifiedByDefault="false"
            app:queryHint="Cari sesuatu di sini..."
            app:queryBackground="@android:color/transparent"
            app:searchIcon="@drawable/img_8" />

    </com.google.android.material.card.MaterialCardView>


    <androidx.recyclerview.widget.RecyclerView
        android:layout_marginTop="30dp"
        app:layout_constraintTop_toBottomOf="@id/searchDataKategori"
        android:id="@+id/rvDataKategori"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        tools:listitem="@layout/layout_item_kategori"/>

    <com.google.android.material.button.MaterialButton
        android:layout_width="wrap_content"
        android:id="@+id/btnTambahKategori"
        android:layout_height="wrap_content"
        android:background="@drawable/img_13"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="10dp"
        android:layout_marginEnd="15dp"
        app:backgroundTint="@null"
        app:layout_constraintBottom_toBottomOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>