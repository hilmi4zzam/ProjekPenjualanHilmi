<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="4dp">
    
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">
        
        <com.google.android.material.card.MaterialCardView
            android:layout_width="50dp"
            app:layout_constraintStart_toStartOf="parent"
            android:id="@+id/logokategori"
            android:layout_height="50dp"
            app:strokeWidth="0dp"
            tools:ignore="MissingConstraints"
            android:backgroundTint="#b36f32">

            <ImageView
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_gravity="center"
                android:background="@drawable/img_9"/>

        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Kategori"
            android:fontFamily="@font/alata"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/logokategori"
            android:textSize="20sp"
            android:layout_marginBottom="5dp"
            android:layout_marginStart="20dp"
            android:textColor="@color/black"/>

        <com.google.android.material.chip.Chip
            android:id="@+id/chipAdd"
            android:layout_width="wrap_content"
            android:layout_height="56dp"
            android:text="Aktif"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:textSize="20sp"

            app:chipIcon="@drawable/img_10"
            app:chipIconSize="20dp"
            app:chipIconVisible="true"

            app:chipStrokeWidth="1dp"
            app:chipStrokeColor="#D0D0D0"

            app:chipCornerRadius="5dp"/>
        
    </androidx.constraintlayout.widget.ConstraintLayout>
    
</com.google.android.material.card.MaterialCardView>